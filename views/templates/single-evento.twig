{% extends "base.twig" %}

{% set evento = function("get_field", "evento", post.ID) %}
{% set tipologia = function("wp_get_post_terms", post.ID, "tipologia-evento") %}
{% set luogo = function("wp_get_post_terms", post.ID, "luogo-evento") %}

{% set progetto_fields = evento.usa_contenuti_progetto and evento.progetto_correlato
  ? function("get_field", "progetto", evento.progetto_correlato.ID)
  : null
%}
{% set active_tabs = progetto_fields ? progetto_fields.tabs : evento.tabs %}

{% set date_format = {
  anno: "Y",
  anno_mese: "F Y",
  anno_mese_giorno: "d F Y"
}[evento.precisione_date ?? "anno_mese_giorno"]
  ?? "d F Y"
%}

{% block hero %}
  {% set hero_title = post.title %}
  {% set hero_title_style = "news" %}
  {{ include("components/hero/hero.twig") }}
{% endblock hero %}

{% block content %}
  <div class="border-b-stroke mx-auto grid grid-cols-3 border-b">
    {# Tabs — cols 1–2 #}
    <div class="col-span-3 xl:col-span-2">
      {% if active_tabs %}
        {{
          include(
            "components/tabs/tabs.twig",
            { component: { tabs: active_tabs, full_width: true } }
          )
        }}
      {% endif %}
    </div>

    {# Informazioni — col 3 #}
    <div
      class="border-stroke col-span-3 flex flex-col gap-10 border-t border-l px-6 py-10 xl:col-span-1 xl:p-10"
    >
      <h2 class="heading-h6 font-semibold">Informazioni</h2>

      {% if evento.data_inizio or evento.data_fine %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            Data
          </span>
          <span class="text-tight text-xl">
            {% if evento.data_inizio %}{{
              evento.data_inizio|date(date_format)
            }}{% endif %}
            {% if evento.data_fine %}
              — {{ evento.data_fine|date(date_format) }}
            {% endif %}
          </span>
        </div>
      {% endif %}

      {% if tipologia %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            Tipologia
          </span>
          <span class="text-tight text-xl">
            {{ tipologia|map(t => t.name)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if luogo %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">Luogo</span>
          <span class="text-tight text-xl">
            {{ luogo|map(t => t.name)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if evento.relatori_ospiti %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            Relatori / Ospiti
          </span>
          <span class="text-tight text-xl">
            {{ evento.relatori_ospiti|map(r => r.nome)|join(" · ") }}
          </span>
        </div>
      {% endif %}

      {% if evento.descrizione_estesa %}
        <div class="flex flex-col gap-2">
          <span class="text-tight text-xl font-semibold text-black">
            Descrizione
          </span>
          <div class="prose text-tight max-w-none text-xl">
            {{ evento.descrizione_estesa }}
          </div>
        </div>
      {% endif %}

      {% if evento.links %}
        <div class="mt-auto flex flex-col gap-3">
          {% for item in evento.links %}
            {% if item.link %}
              {% include "components/button.twig" with {
                as_link: true,
                size: "lg",
                variant: item.stile == "secondary"
                  ? "outline"
                  : item.stile == "link" ? "link" : "default",
                label: item.link.title,
                attributes: {
                  href: item.link.url,
                  target: item.link.target ? : "_self",
                  class: "w-full"
                }
              } %}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>

  {% set galleria = function("get_field", "galleria_evento", post.ID) %}
  {% if galleria.items %}
    {{
      include(
        "components/media-displayer/media-displayer.twig",
        { component: galleria }
      )
    }}
  {% endif %}

  {% set partners_displayer = function("get_field", "partners_displayer_evento", post.ID) %}
  {% if partners_displayer.items %}
    {{
      include(
        "components/partners-displayer/partners-displayer.twig",
        { component: partners_displayer }
      )
    }}
  {% endif %}
{% endblock content %}
