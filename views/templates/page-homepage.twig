{% extends "base.twig" %}

{% block content %}
  {% for component in post.components %}
    {% set layout = component.acf_fc_layout|replace({ "_": "-" }) %}
    {{
      include(
        "components/" ~ layout ~ "/" ~ layout ~ ".twig",
        { component: component }
      )
    }}
  {% endfor %}
  <section
    class="flex h-svh w-full flex-col items-center justify-center"
  ></section>
{% endblock content %}
