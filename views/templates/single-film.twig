{% extends "base.twig" %}

{% block hero %}

{% endblock hero %}

{% block content %}
  {% set film_id = post.ID %}
  {% set sezione = function("get_field", "sezione", film_id)[0] %}
  {% set paese = function("wp_get_post_terms", film_id, "paese") %}
  {% set genere = function("wp_get_post_terms", film_id, "genere")[0] %}
  {% set badges = function("wp_get_post_terms", film_id, "badge") %}
  {% set regista = function("get_field", "regista", film_id) %}
  {% set titolo_alternativo =
    function("get_field", "titolo_alternativo", film_id)
  %}
  {% set durata = function("get_field", "durata", film_id) %}
  {% set anno = function("get_field", "anno", film_id) %}
  {% set area_tematica =
    function("wp_get_post_terms", film_id, "area-tematica")
  %}
  {% set description = function("get_field", "description", film_id) %}
  {% set info_aggiuntive = function("get_field", "info_aggiuntive", film_id) %}
  {% set proiezioni = post.get_proiezioni %}

  {# Hero image #}
  {% if post.thumbnail %}
    {% set thumb_id = function("get_post_thumbnail_id", film_id) %}
    {% set fp = thumb_id
      ? function("get_post_meta", thumb_id, "focalpoint", true)
      : null
    %}
    {% set fp_style = fp
      ? "object-position: " ~ ((fp.left * 100)|round) ~ "% "
        ~ ((fp.top * 100)|round)
        ~ "%;"
      : null
    %}
    <div
      class="relative mt-[108px] h-[550px] w-full overflow-hidden lg:h-[600px]"
    >
      <img
        src="{{ post.thumbnail.src("full") }}"
        alt="{{ post.title }}"
        class="h-full w-full object-cover"
        style="{{ fp_style }}"
      />
      {% if badges %}
        <div class="absolute bottom-0 left-0 flex gap-0">
          {% for badge in badges %}
            <span
              class="uppercase {{
              loop.last
                ? ""
                : "border-r border-r-[#575757]"
              }} bg-black/20 px-2 py-1 text-sm font-semibold text-white! backdrop-blur-[50px]"
            >
              {{ badge.name }}
            </span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endif %}

  <div
    class="border-b-stroke 3xl:grid-cols-4 mx-auto grid grid-cols-3 border-b"
  >
    {# Main content — cols 1–2 #}
    <div
      class="3xl:col-span-3 col-span-3 flex flex-col gap-10 pt-20 pr-6 pb-20 pl-6 lg:gap-20 xl:col-span-2 xl:pr-10 xl:pb-30 2xl:pr-10 2xl:pr-30 2xl:pl-10"
    >
      {# Header #}
      <div class="flex flex-col gap-6">
        {{ include("parts/breadcrumbs.twig") }}
        {% if sezione %}
          {% include "components/button.twig" with {
            as_link: true,
            variant: "link",
            label: sezione.post_title,
            attributes: {
              href: function("get_permalink", sezione.ID),
              class: "text-red h-auto p-0 text-sm font-semibold uppercase w-fit"
            }
          } %}
        {% endif %}
        <h1 class="display-h1-tertiary">{{ post.title }}</h1>
      </div>

      {# Info table #}
      <div
        class="grid grid-cols-[auto_1fr] lg:grid-cols-[minmax(auto,_220px)_1fr]"
      >
        {% if regista %}
          <div class="contents">
            <span
              class="border-stroke text-tight border-b pr-8 pb-6 text-base lg:pr-16 lg:text-xl"
            >
              Regista
            </span>
            <span
              class="border-stroke text-tight border-b pb-6 text-base font-semibold lg:text-xl"
            >
              {{ regista }}
            </span>
          </div>
        {% endif %}
        {% if titolo_alternativo %}
          <div class="contents">
            <span
              class="border-stroke text-tight border-b py-6 pr-8 text-base lg:pr-16 lg:text-xl"
            >
              Titolo alternativo
            </span>
            <span
              class="border-stroke text-tight border-b py-6 text-base font-semibold lg:text-xl"
            >
              {{ titolo_alternativo }}
            </span>
          </div>
        {% endif %}
        {% if durata %}
          <div class="contents">
            <span
              class="border-stroke text-tight border-b py-6 pr-8 text-base lg:pr-16 lg:text-xl"
            >
              Durata
            </span>
            <span
              class="border-stroke text-tight border-b py-6 text-base font-semibold lg:text-xl"
            >
              {{ durata }}
            </span>
          </div>
        {% endif %}
        {% if paese %}
          <div class="contents">
            <span
              class="border-stroke text-tight border-b py-6 pr-8 text-base lg:pr-16 lg:text-xl"
            >
              Paese
            </span>
            <span
              class="border-stroke text-tight border-b py-6 text-base font-semibold lg:text-xl"
            >
              {{ paese|map(t => t.name)|join(", ") }}
            </span>
          </div>
        {% endif %}
        {% if anno %}
          <div class="contents">
            <span
              class="border-stroke text-tight border-b py-6 pr-8 text-base lg:pr-16 lg:text-xl"
            >
              Anno
            </span>
            <span
              class="border-stroke text-tight border-b py-6 text-base font-semibold lg:text-xl"
            >
              {{ anno }}
            </span>
          </div>
        {% endif %}
        {% if genere %}
          <div class="contents">
            <span
              class="border-stroke text-tight border-b py-6 pr-8 text-base lg:pr-16 lg:text-xl"
            >
              Genere
            </span>
            <span
              class="border-stroke text-tight border-b py-6 text-base font-semibold lg:text-xl"
            >
              {{ genere.name }}
            </span>
          </div>
        {% endif %}
        {% if area_tematica %}
          <div class="contents">
            <span
              class="border-stroke text-tight border-b py-6 pr-8 text-base lg:pr-16 lg:text-xl"
            >
              Aree tematiche
            </span>
            <span
              class="border-stroke text-tight border-b py-6 text-base font-semibold lg:text-xl"
            >
              {% for term in area_tematica %}
                {% include "components/button.twig" with {
                  as_link: true,
                  variant: "link",
                  label: term.name,
                  attributes: {
                    href: function("get_post_type_archive_link", "film")
                      ~ "?_area_tematica="
                      ~ term.slug,
                    class: "h-auto p-0 text-base font-semibold lg:text-xl"
                  }
                } %}
                {% if not loop.last %}, {% endif %}
              {% endfor %}
            </span>
          </div>
        {% endif %}
        {% if info_aggiuntive %}
          {% for row in info_aggiuntive %}
            <div class="contents">
              <span
                class="border-stroke text-tight border-b py-6 pr-8 text-base lg:pr-16 lg:text-xl"
              >
                {{ row.titolo }}
              </span>
              <span
                class="border-stroke text-tight border-b py-6 text-base font-semibold lg:text-xl"
              >
                {{ row.contenuto }}
              </span>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      {# Description #}
      {% if description %}
        <div
          class="prose font-regular max-w-none text-base leading-[150%] text-black/80"
        >
          {{ description }}
        </div>
      {% endif %}
    </div>

    {# Proiezioni — col 3 #}
    {% if proiezioni %}
      <div
        class="border-l-stroke col-span-3 flex flex-col gap-10 pb-12 lg:border-l xl:col-span-1 xl:py-12"
      >
        <h2 class="heading-h6 px-6 font-semibold xl:px-10">Programmazione</h2>
        <div class="flex flex-col gap-12">
          {% for proiezione in proiezioni %}
            {% set location =
              function("wp_get_post_terms", proiezione.ID, "location")[0]
            %}
            {% set p_data = function("get_field", "data", proiezione.ID) %}
            {% set p_orario = function("get_field", "orario", proiezione.ID) %}
            {% set p_descrizione =
              function("get_field", "descrizione_proiezione", proiezione.ID)
            %}
            {% set p_biglietto =
              function("get_field", "link_biglietto", proiezione.ID)
            %}
            {% set p_mymovies =
              function("get_field", "link_mymovies", proiezione.ID)
            %}
            {% set p_link_extra =
              function("get_field", "link_personalizzabile", proiezione.ID)
            %}
            {% set p_sala_location =
              function("get_field", "sala_location", proiezione.ID)
            %}

            {% if not loop.first %}
              <div class="flex items-center gap-4">
                <span class="border-stroke flex-1 border-t"></span>
                <span class="text-tight text-xl text-black">oppure</span>
                <span class="border-stroke flex-1 border-t"></span>
              </div>
            {% endif %}

            <div class="flex flex-col gap-6 px-6 xl:px-10">
              <div class="flex flex-col gap-6">
                <div class="flex flex-col gap-2">
                  {% if p_data or p_orario %}
                    <p class="text-tight text-xl font-semibold">
                      {{ p_data|date("d F Y") }}{% if p_orario %}
                        · {{ p_orario|date("H:i") }}
                      {% endif %}
                    </p>
                  {% endif %}
                  {% if location %}
                    <p class="text-tight text-xl">
                      {{ location.name }}{{ p_sala_location ? " – " ~ p_sala_location : "" }}
                    </p>
                  {% endif %}
                </div>
                {% if p_descrizione %}
                  <div class="text-tight text-base text-black">
                    {{ p_descrizione }}
                  </div>
                {% endif %}
              </div>
              {% if p_biglietto or p_link_extra or p_mymovies %}
                <div class="flex flex-col gap-3">
                  {% if p_biglietto %}
                    {% include "components/button.twig" with {
                      as_link: true,
                      variant: "default",
                      size: "lg",
                      label: p_biglietto.title ? : "Compra biglietto",
                      attributes: {
                        href: p_biglietto.url ?? p_biglietto,
                        target: p_biglietto.target ?? "_self",
                        class: "xl:w-full md:w-fit w-full"
                      }
                    } %}
                  {% endif %}
                  {% if p_link_extra %}
                    {% include "components/button.twig" with {
                      as_link: true,
                      variant: "default",
                      size: "lg",
                      label: p_link_extra.title,
                      attributes: {
                        href: p_link_extra.url,
                        target: p_link_extra.target ?? "_self",
                        class: "xl:w-full md:w-fit w-full"
                      }
                    } %}
                  {% endif %}
                  {% if p_mymovies %}
                    {% include "components/button.twig" with {
                      as_link: true,
                      variant: "secondary",
                      size: "lg",
                      label: p_mymovies.title ? : "Guarda online su MyMovies",
                      attributes: {
                        href: p_mymovies.url ?? p_mymovies,
                        target: p_mymovies.target ?? "_self",
                        class: "xl:w-full md:w-fit md:bg-black/3 xl:bg-white w-full"
                      }
                    } %}
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
  {% if related_films %}
    {{
      include(
        "components/card-displayer/card-displayer.twig",
        {
          component: {
            title: "Scopri anche",
            items: related_films,
            always_even: true
          }
        }
      )
    }}
  {% endif %}
{% endblock content %}
