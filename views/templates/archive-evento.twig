{% extends "base.twig" %}

{% block hero %}
  {{
    include(
      "components/hero/hero.twig",
      { hero_title: "Eventi Campus", hero_title_style: "primary" }
    )
  }}
{% endblock hero %}

{% block content %}
  <section
    class="w-full"
    x-data="{ filtersOpen: false }"
    x-effect="document.body.style.overflow = filtersOpen ? 'hidden' : ''"
    @keydown.escape.window="filtersOpen = false"
  >
    {% set intro_title = function("get_field", "eventi_titolo", "option") %}
    {% set intro_desc = function("get_field", "eventi_descrizione", "option") %}
    {% if intro_title or intro_desc %}
      <div
        class="introduction flex w-full flex-col gap-4 px-6 pt-0 pb-20 xl:w-2/3 xl:px-10 xl:pb-30"
      >
        {% if intro_title %}
          <h4 class="heading-h4 font-semibold">{{ intro_title }}</h4>
        {% endif %}
        {% if intro_desc %}
          <p class="text-xl">
            {{ intro_desc }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div id="filters-sentinel" class="h-0"></div>

    {# ── Mobile filter bar (< lg) ── #}
    <div
      data-sticky-top
      class="filters-black top-0 z-50 mb-20 flex w-full lg:hidden"
    >
      <button
        type="button"
        class="text-tight border-stroke hover:bg-white-hover active:bg-white-active flex cursor-pointer items-center gap-2 border bg-white px-4 py-3 text-base text-black uppercase transition-colors focus-visible:z-10 focus-visible:ring-2 focus-visible:ring-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-black"
        @click="filtersOpen = true"
      >
        {{
          include("icons/generic/filters.svg")|attr({
            class: "size-5 shrink-0"
          })
        }}
        Filtri
        <span class="filters-active-dot bg-red hidden size-2 rounded-full">

        </span>
      </button>
      <div class="flex-1 border-y border-white/20 bg-black"></div>
    </div>

    {# ── Desktop filter bar (lg+) ── #}
    <div
      data-sticky-top
      class="filters-black top-0 z-50 mb-20 hidden w-full justify-between bg-black lg:flex"
    >
      <div class="w-1/3">
        {{ function("do_shortcode", '[facetwp facet="tipologia_evento"]') }}
      </div>
      <button
        type="button"
        class="text-tight border-stroke hover:bg-white-hover active:bg-white-active -ml-px cursor-pointer border bg-white px-4 py-3 text-base text-black uppercase transition-colors focus-visible:z-10 focus-visible:ring-2 focus-visible:ring-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-black"
        onclick="FWP.reset()"
      >
        Reset
      </button>
    </div>

    {% include "parts/filters-drawer.twig" with {
      state_var: "filtersOpen",
      facets: ["tipologia_evento", "luogo_evento"]
    } %}

    <div class="facetwp-template">
      <div
        class="border-stroke 3xl:grid-cols-4 grid w-full grid-cols-1 md:grid-cols-2 xl:grid-cols-3"
      >
        {% for post in posts %}
          {{
            include(
              "parts/cards/evento-card.twig",
              { evento: post, extra_class: "" }
            )
          }}
        {% else %}
          <p
            class="text-tight col-span-full py-30 text-center text-xl font-semibold text-black"
          >
            Nessun risultato per i filtri selezionati.<br />Prova a modificare
            la ricerca o resetta i filtri.
          </p>
        {% endfor %}

        {# 2-col fillers #}
        {% set count = posts|length %}
        {% if count % 2 == 1 %}
          <div class="border-stroke col-span-1 border-l xl:hidden"></div>
        {% endif %}

        {# 3-col fillers #}
        {% if count % 3 == 1 %}
          <div
            class="border-stroke 3xl:hidden col-span-1 hidden border-l xl:block"
          ></div>
          <div class="3xl:hidden col-span-1 hidden xl:block"></div>
        {% elseif count % 3 == 2 %}
          <div
            class="border-stroke 3xl:hidden col-span-1 hidden border-l xl:block"
          ></div>
        {% endif %}

        {# 4-col fillers #}
        {% if count % 4 == 1 %}
          <div class="border-stroke 3xl:block col-span-1 hidden border-l"></div>
          <div class="3xl:block col-span-1 hidden"></div>
          <div class="3xl:block col-span-1 hidden"></div>
        {% elseif count % 4 == 2 %}
          <div class="border-stroke 3xl:block col-span-1 hidden border-l"></div>
          <div class="3xl:block col-span-1 hidden"></div>
        {% elseif count % 4 == 3 %}
          <div class="border-stroke 3xl:block col-span-1 hidden border-l"></div>
        {% endif %}
      </div>
    </div>
  </section>

  {% include "parts/pagination.twig" with {
    pagination: posts.pagination({ show_all: false, mid_size: 3, end_size: 2 })
  } %}
{% endblock content %}
