{% extends "base.twig" %}

{% block content %}
  {{ include("components/locations/locations.twig", { component: post }) }}
  {% for component in post.page_components %}
    {% set layout = component.acf_fc_layout|replace({ "_": "-" }) %}
    {% if component.anchor %}
      <div id="{{ component.anchor }}" class="scroll-mt-28"></div>
    {% endif %}
    {{
      include(
        "components/" ~ layout ~ "/" ~ layout ~ ".twig",
        { component: component }
      )
    }}
  {% endfor %}
{% endblock content %}
