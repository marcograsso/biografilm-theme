<div
  x-show="menuOpen"
  x-cloak
  x-transition:enter="transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]"
  x-transition:enter-start="grid-rows-[0fr]"
  x-transition:enter-end="grid-rows-[1fr]"
  x-transition:leave="transition-[grid-template-rows] duration-200 ease-[cubic-bezier(0.22,1,0.36,1)]"
  x-transition:leave-start="grid-rows-[1fr]"
  x-transition:leave-end="grid-rows-[0fr]"
  class="absolute top-full left-0 z-10 grid w-full bg-white"
>
  <div class="overflow-hidden">
    <div class="border-t-stroke border-b-stroke border-t border-b p-6 xl:p-10">
      {% if menu_submenu %}
        <nav class="flex justify-between gap-3">
          {% for item in menu_submenu.items %}
            <div class="flex flex-col gap-4">
              {% if item.url == '#no-link' %}
                <span
                  class="text-tight py-0.4 w-fit text-2xl leading-[125%] font-semibold text-black"
                >
                  {{ item.title }}
                </span>
              {% else %}
                <a
                  href="{{ item.url }}"
                  class="text-tight focusable link-underline py-0.4 active:text-black-active w-fit cursor-pointer text-2xl leading-[125%] font-semibold text-black [&::after]:bottom-0"
                >
                  {{ item.title }}
                </a>
              {% endif %}
              {% if item.children %}
                <ul class="flex flex-col gap-3">
                  {% for child in item.children %}
                    <li>
                      {% if child.url == '#no-link' %}
                        <span
                          class="text-tight w-fit text-base font-normal text-black/80"
                        >
                          {{ child.title }}
                        </span>
                      {% else %}
                        <a
                          href="{{ child.url }}"
                          class="text-tight focusable link-underline active:text-black-active w-fit cursor-pointer py-0.5 text-base font-normal text-black/80 [--link-underline-height:1px] [&::after]:bottom-0"
                        >
                          {{ child.title }}
                        </a>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          {% endfor %}
        </nav>
      {% endif %}
    </div>
  </div>
</div>
