{% if component.tickets %}
  <section class="border-stroke w-full border-t">
    <div class="3xl:grid-cols-4 grid w-full grid-cols-3 py-20 xl:py-0">
      {# Left 1/3: heading + subtitle #}
      <div
        class="3xl:col-span-1 border-stroke col-span-3 flex h-full flex-col gap-6 border-r p-6 xl:col-span-1 xl:p-10"
      >
        {% if component.heading %}
          <h2 class="heading-h4 font-semibold text-black">
            {{ component.heading }}
          </h2>
        {% endif %}
        {% if component.subtitle %}
          <p class="text-tight text-2xl leading-[150%] text-black">
            {{ component.subtitle }}
          </p>
        {% endif %}
      </div>

      {# Right 2/3: tickets list #}
      <div
        class="3xl:col-span-3 col-span-3 flex flex-col p-6 xl:col-span-2 xl:p-10"
      >
        {% for ticket in component.tickets %}
          <div
            class="border-stroke flex flex-col py-10 first:pt-0 {{
            loop.last
              ? ""
              : "border-b"
            }} {{
            ticket.sub_tickets or ticket.description_title or ticket.description
              ? "gap-6"
              : "gap-3"
            }}"
            x-data="{ open: true }"
          >
            <div class="flex items-start gap-4">
              {# Titles/subtitles/prices block #}
              <div class="flex flex-1 flex-col gap-3">
                <div class="flex items-start justify-between gap-4">
                  {% if ticket.name %}
                    <div
                      class="text-tight prose heading-h6 [&_a]:hover:text-black-hover [&_a]:active:text-black-active font-semibold text-black [&_a]:underline [&_a]:underline-offset-5"
                    >
                      {{ ticket.name|raw }}
                    </div>
                  {% endif %}
                  {% if ticket.price %}
                    <span
                      class="text-tight heading-h6 block text-right font-semibold"
                    >
                      {{ ticket.price }}
                    </span>
                  {% endif %}
                </div>
                {% for sub in ticket.sub_tickets %}
                  <div class="flex items-start justify-between gap-4">
                    {% if sub.name %}
                      <div
                        class="[&_p]:text-tight [&_a]:hover:text-black-hover [&_a]:active:text-black-active text-2xl leading-[150%] text-black/80 [&_a]:underline [&_a]:underline-offset-5"
                      >
                        {{ sub.name|raw }}
                      </div>
                    {% endif %}
                    {% if sub.price %}
                      <span
                        class="text-tight heading-h6 block text-right text-2xl font-semibold"
                      >
                        {{ sub.price }}
                      </span>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
              {# Chevron toggle #}
              {% if ticket.description_title or ticket.description %}
                <button
                  @click="open = !open"
                  class="cursor-pointer self-start transition-transform duration-300"
                  :class="open ? 'rotate-180' : ''"
                  aria-label="Toggle description"
                >
                  {{
                    include("icons/generic/chevron-big.svg")|attr({
                      class: "size-9"
                    })
                  }}
                </button>
              {% endif %}
            </div>
            {% if ticket.description_title or ticket.description %}
              <div class="flex flex-col gap-2" x-show="open" x-collapse>
                {% if ticket.description_title %}
                  <p class="text-tight text-2xl font-semibold text-black">
                    {{ ticket.description_title }}
                  </p>
                {% endif %}
                {% if ticket.description %}
                  <div
                    class="text-tight prose text-xl leading-[150%] text-black/80"
                  >
                    {{ ticket.description|raw }}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
        {% if component.links %}
          <div class="flex flex-wrap gap-4 pt-20">
            {% for item in component.links %}
              {% if item.link %}
                {{
                  include(
                    "components/button.twig",
                    {
                      as_link: true,
                      label: item.link.title,
                      variant: item.style ? : "default",
                      size: "lg",
                      attributes: {
                        href: item.link.url,
                        target: item.link.target ? : "_self",
                        class: "w-full border-black border"
                      }
                    }
                  )
                }}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}
