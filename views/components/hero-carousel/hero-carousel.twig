<div
  class="swiper hero-carousel mt-[108px] min-h-160 w-full [--swiper-navigation-color:var(--color-white)] [--swiper-pagination-bullet-inactive-color:var(--color-white/50)] [--swiper-pagination-color:var(--color-white)]"
  style="height: calc(100vh - 108px);"
>
  <div class="swiper-wrapper">
    {% for slide in component.hero_carousel_slides %}
      <div
        class="swiper-slide relative min-h-160 w-full overflow-hidden bg-zinc-900 bg-cover bg-center"
        style="height: calc(100vh - 108px);{{
        slide.background_image and not slide.background_video
          ? " background-image: url(" ~ slide.background_image.url ~ ");"
          : ""
        }}"
      >
        {% if slide.background_video %}
          <video
            class="absolute inset-0 h-full w-full object-cover"
            src="{{ slide.background_video.url }}"
            autoplay
            muted
            loop
            playsinline
          ></video>
        {% endif %}
        <div
          class="glass-effect absolute bottom-0 left-0 flex flex-col gap-6 bg-white/20 p-6 pb-20 md:pb-6 lg:pl-10 {{
          slide.text_width == "w-1/3"
            ? "w-full md:w-1/2 xl:w-1/3"
            : "w-full md:w-1/2"
          }}"
          style="{{
          slide.text_color
            ? " color: " ~ slide.text_color ~ ";"
            : ""
          }}"
        >
          {% if slide.logo %}
            <img
              src="{{ slide.logo.url }}"
              alt="{{ slide.logo.alt }}"
              class="self-start object-contain"
            />
          {% endif %}
          {% if slide.title or slide.subtitle %}
            <div>
              {% if slide.title %}
                <h2
                  class="heading-h6 font-sans leading-[125%] font-semibold tracking-normal"
                >
                  {{ slide.title }}
                </h2>
              {% endif %}
              {% if slide.subtitle %}
                <p
                  class="heading-h6 font-sans leading-[125%] font-normal tracking-normal"
                >
                  {{ slide.subtitle }}
                </p>
              {% endif %}
            </div>
          {% endif %}
          {% if slide.link %}
            {{
              include(
                "components/button.twig",
                {
                  label: slide.link.title,
                  as_link: true,
                  variant: "default",
                  size: "lg",
                  attributes: {
                    href: slide.link.url,
                    target: slide.link.target ? : "_self"
                  }
                }
              )
            }}
            {{
              include(
                "components/button.twig",
                {
                  label: slide.link.title,
                  as_link: true,
                  variant: "secondary",
                  size: "lg",
                  attributes: {
                    href: slide.link.url,
                    target: slide.link.target ? : "_self"
                  }
                }
              )
            }}
          {% endif %}
          {% if slide.description %}
            <span class="text-tight block text-2xl opacity-90">
              {{ slide.description }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
  <div class="hero-carousel-nav">
    <button class="swiper-button-prev" aria-label="Previous slide"></button>
    <div class="swiper-pagination" role="tablist"></div>
    <button class="swiper-button-next" aria-label="Next slide"></button>
  </div>
</div>
