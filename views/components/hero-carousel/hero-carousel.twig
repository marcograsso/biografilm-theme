<div
  class="swiper hero-carousel h-screen w-full [--swiper-navigation-color:var(--color-white)] [--swiper-pagination-bullet-inactive-color:var(--color-white/50)] [--swiper-pagination-color:var(--color-white)]"
>
  <div class="swiper-wrapper">
    {% for slide in post.hero_carousel_slides %}
      <div
        class="swiper-slide relative !h-screen w-full bg-zinc-900 bg-cover bg-center"
        style="{{
        slide.background_image
          ? "background-image: url(" ~ slide.background_image.url ~ ");"
          : ""
        }}"
      >
        <div
          class="glass-effect absolute bottom-0 left-0 flex flex-col gap-6 bg-white/20 {{
          slide.text_width == "w-1/3"
            ? "w-full md:w-1/2 lg:w-1/3"
            : "w-full md:w-1/2"
          }}"
          style="padding: 40px 30px 40px 40px;{{
          slide.text_color
            ? " color: " ~ slide.text_color ~ ";"
            : ""
          }}"
        >
          {% if slide.logo %}
            <img
              src="{{ slide.logo.url }}"
              alt="{{ slide.logo.alt }}"
              class="self-start object-contain"
            />
          {% endif %}
          {% if slide.title or slide.subtitle %}
            <div>
              {% if slide.title %}
                <h2
                  class="font-sans text-[2rem] leading-[125%] font-semibold tracking-normal"
                >
                  {{ slide.title }}
                </h2>
              {% endif %}
              {% if slide.subtitle %}
                <p
                  class="font-sans text-[2rem] leading-[125%] font-normal tracking-normal"
                >
                  {{ slide.subtitle }}
                </p>
              {% endif %}
            </div>
          {% endif %}
          {% if slide.link %}
            {{
              include(
                "components/button.twig",
                {
                  label: slide.link.title,
                  as_link: true,
                  variant: "default",
                  size: "lg",
                  attributes: {
                    href: slide.link.url,
                    target: slide.link.target ? : "_self"
                  }
                }
              )
            }}
          {% endif %}
          {% if slide.description %}
            <span class="block text-2xl opacity-90">
              {{ slide.description }}
            </span>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
  <div class="hero-carousel-nav">
    <button class="swiper-button-prev" aria-label="Previous slide"></button>
    <div class="swiper-pagination" role="tablist"></div>
    <button class="swiper-button-next" aria-label="Next slide"></button>
  </div>
</div>
