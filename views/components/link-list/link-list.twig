{% if component.links %}
  <section class="border-stroke w-full {{ prev_layout == 'link-list' ? '' : 'border-t' }}">
    <div class="3xl:grid-cols-4 grid w-full grid-cols-3 py-0">
      {# Left 1/3: heading + subtitle #}
      <div
        class="3xl:col-span-1 border-stroke col-span-3 flex h-full flex-col gap-6 border-r border-b px-6 py-10 xl:col-span-1 xl:border-b-0 xl:p-10"
      >
        {% if component.heading %}
          <h2 class="heading-h4 font-semibold text-black">
            {{ component.heading }}
          </h2>
        {% endif %}
        {% if component.subtitle %}
          <p class="text-tight text-2xl leading-[150%] text-black">
            {{ component.subtitle }}
          </p>
        {% endif %}
      </div>

      {# Right 2/3: links grid #}
      <div class="3xl:col-span-3 col-span-3 xl:col-span-2">
        {% set count = component.links|length %}
        <div class="border-stroke grid grid-cols-1 md:grid-cols-2 3xl:grid-cols-3">
          {% for item in component.links %}
            {% set href = item.document ? item.document.url : (item.link ? item.link.url : null) %}
            {% set target = item.document ? '_blank' : (item.link ? (item.link.target ?: '_self') : '_self') %}
            {% set label = item.title ?: (item.link ? item.link.title : item.document.filename) %}
            {% if href %}
              <a
                href="{{ href }}"
                target="{{ target }}"
                class="group border-stroke flex items-center justify-between gap-4 border-b p-6 transition-colors duration-300 md:border-r md:[&:nth-child(even)]:border-r-0 3xl:[&:nth-child(even)]:border-r 3xl:[&:nth-child(3n)]:border-r-0 xl:p-10"
              >
                <span class="text-tight heading-h6 text-2xl line-clamp-2 font-semibold text-black">
                  {{ label }}
                </span>
                <span class="relative block size-9 shrink-0 overflow-hidden">
                  <span
                    class="absolute inset-0 transition-transform duration-500 ease-in-out group-hover:translate-x-9"
                  >
                    {{
                      include("icons/generic/arrow-right-big.svg")|attr({ class: "size-9" })
                    }}
                  </span>
                  <span
                    class="absolute inset-0 -translate-x-9 transition-transform duration-500 ease-in-out group-hover:translate-x-0"
                  >
                    {{
                      include("icons/generic/arrow-right-big.svg")|attr({ class: "size-9" })
                    }}
                  </span>
                </span>
              </a>
            {% endif %}
          {% endfor %}
          {# 2-col filler #}
          {% if count % 2 == 1 %}
            <div class="border-stroke 3xl:hidden border-b md:border-r"></div>
          {% endif %}
          {# 3-col fillers #}
          {% if count % 3 == 1 %}
            <div class="border-stroke 3xl:block hidden border-b"></div>
            <div class="border-stroke 3xl:block hidden border-b"></div>
          {% elseif count % 3 == 2 %}
            <div class="border-stroke 3xl:block hidden border-b"></div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>
{% endif %}
