{% if component.items %}
  {# Build modal items array #}
  {% set media_items = [] %}
  {% for item in component.items %}
    {% set layout = item.acf_fc_layout %}
    {% if layout == "immagine" and item.immagine %}
      {% set fp = item.immagine.ID
        ? function("get_post_meta", item.immagine.ID, "focalpoint", true)
        : null
      %}
      {% set media_items =
        media_items|merge(
          [
            {
              type: "image",
              url: item.immagine.url,
              alt: item.immagine.alt,
              fp: fp
                ? ((fp.left * 100)|round) ~ "% " ~ ((fp.top * 100)|round) ~ "%"
                : null
            }
          ]
        )
      %}
    {% elseif layout == "video_file" and item.file %}
      {% set media_items =
        media_items|merge(
          [
            {
              type: "video_file",
              url: item.file.url,
              mime_type: item.file.mime_type
            }
          ]
        )
      %}
    {% elseif layout == "video_url" and item.url %}
      {% set media_items =
        media_items|merge([{ type: "video_url", html: item.url }])
      %}
    {% endif %}
  {% endfor %}

  <section
    class="w-full"
    x-data="{
      open: false,
      current: 0,
      items: [],
      init() {
        this.items = JSON.parse(this.$el.querySelector('[data-media-items]').textContent);
        this.$watch('open', val => { document.body.style.overflow = val ? 'hidden' : ''; });
      },
      get total() { return this.items.length; },
      get currentItem() { return this.items[this.current]; },
      stopMedia() {
        const v = this.$refs.modalVideo;
        if (v) { v.pause(); v.removeAttribute('src'); v.load(); }
        const d = this.$refs.modalVideoUrl;
        if (d) { d.innerHTML = ''; }
      },
      openAt(i) { this.current = i; this.open = true; },
      prev() { this.stopMedia(); this.current = (this.current - 1 + this.total) % this.total; },
      next() { this.stopMedia(); this.current = (this.current + 1) % this.total; },
      close() { this.stopMedia(); this.open = false; }
    }"
    @keydown.escape.window="if (open) close()"
    @keydown.arrow-left.window="if (open) prev()"
    @keydown.arrow-right.window="if (open) next()"
  >
    <script type="application/json" data-media-items>
      {{ media_items|json_encode(constant("JSON_HEX_TAG"))|raw }}
    </script>

    {% set borders = component.borders_group %}
    <div class="3xl:grid-cols-4 grid w-full grid-cols-3">
      {# Title column #}
      <div
        class="3xl:col-span-1 col-span-3 flex flex-col gap-2 px-6 pt-20 pb-10 xl:col-span-1 xl:px-10 xl:py-30 {{
        borders.border_top or borders.border_bottom
          ? "border-stroke"
          : ""
        }} {{ borders.border_top ? "border-t" : "" }} {{
        borders.border_bottom
          ? "border-b"
          : "border-b border-stroke xl:border-b-0"
        }}"
      >
        {% if component.title %}
          <h4 class="heading-h4 blur-in font-semibold">
            {{ component.title }}
          </h4>
        {% endif %}
        {% if component.link %}
          <a
            href="{{ component.link.url }}"
            target="{{ component.link.target ? : "_self" }}"
            class="blur-in text-tight text-red group flex items-center gap-2 text-xl font-semibold"
          >
            <span class="link-underline">{{ component.link.title }}</span>
            {{
              include("icons/generic/arrow-right.svg")|attr({
                class: "size-6 transition-transform duration-500 ease-out group-hover:translate-x-2"
              })
            }}
          </a>
        {% endif %}
      </div>

      {# Media grid #}
      <div
        class="3xl:col-span-3 3xl:grid-cols-3 col-span-3 grid grid-cols-1 md:grid-cols-2 xl:col-span-2 {{
        borders.cards_border_top or borders.cards_border_bottom
          ? "border-stroke"
          : ""
        }} {{ borders.cards_border_top ? "border-t" : "" }} {{
        borders.cards_border_bottom
          ? "border-b"
          : ""
        }}"
      >
        {% set count = component.items|length %}
        {% set always_even = component.always_even %}
        {% set is_odd = count % 2 == 1 %}
        {% set filler_border = borders.filler_border_bottom ? "border-b" : "" %}
        {% for item in component.items %}
          {% set is_last = loop.last %}
          {% set hide_last = always_even and is_odd and is_last %}
          {% set layout = item.acf_fc_layout %}
          {% set idx = loop.index0 %}

          {% if layout == "immagine" and item.immagine %}
            {% set fp = item.immagine.ID
              ? function("get_post_meta", item.immagine.ID, "focalpoint", true)
              : null
            %}
            {% set fp_style = fp
              ? "object-position: " ~ ((fp.left * 100)|round) ~ "% "
                ~ ((fp.top * 100)|round)
                ~ "%;"
              : null
            %}
            <div
              class="col-span-1 aspect-8/5 w-full cursor-pointer overflow-hidden bg-gray-200 {{
              hide_last
                ? "hidden 3xl:block"
                : ""
              }}"
              @click="openAt({{ idx }})"
            >
              <img
                src="{{ item.immagine.url }}"
                alt="{{ item.immagine.alt }}"
                class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
                style="{{ fp_style }}"
              />
            </div>
          {% elseif layout == "video_file" and item.file %}
            <div
              class="col-span-1 aspect-8/5 w-full cursor-pointer bg-black {{
              hide_last
                ? "hidden 3xl:block"
                : ""
              }}"
              @click="openAt({{ idx }})"
            >
              <div class="h-full w-full overflow-hidden">
                <video
                  class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
                  preload="metadata"
                >
                  <source
                    src="{{ item.file.url }}"
                    type="{{ item.file.mime_type }}"
                  />
                </video>
              </div>
            </div>
          {% elseif layout == "video_url" and item.url %}
            <div
              class="relative col-span-1 aspect-8/5 w-full cursor-pointer overflow-hidden bg-black {{
              hide_last
                ? "hidden 3xl:block"
                : ""
              }}"
              @click="openAt({{ idx }})"
            >
              <div
                class="absolute inset-0 overflow-hidden transition-transform duration-500 hover:scale-105 [&_iframe]:pointer-events-none [&_iframe]:absolute [&_iframe]:inset-0 [&_iframe]:h-full [&_iframe]:w-full"
              >
                {{ item.url }}
              </div>
            </div>
          {% endif %}
        {% endfor %}

        {# Fillers to complete the last row #}
        {% set remainder_3col = count % 3 %}
        {% set filler_3col = remainder_3col > 0 ? 3 - remainder_3col : 0 %}

        {% if is_odd and not always_even %}
          <div
            class="border-stroke 3xl:hidden col-span-1 border-l {{
            filler_border
            }}"
          ></div>
        {% endif %}

        {% if filler_3col > 0 %}
          {% for i in 1..filler_3col %}
            <div
              class="border-stroke 3xl:block col-span-1 hidden border-l {{
              filler_border
              }}"
            ></div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {# Lightbox modal — teleported to <body> to escape ScrollSmoother transform stacking context #}
    <template x-teleport="body">
      <div
        class="fixed inset-0 z-[50000] flex h-screen w-screen flex-col bg-black/95"
        x-show="open"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        style="display: none;"
      >
        {# Media area #}
        <div
          class="flex min-h-0 flex-1 items-center justify-center p-6 xl:p-10"
        >
          <img
            x-show="currentItem && currentItem.type === 'image'"
            :src="currentItem ? currentItem.url : ''"
            :alt="currentItem ? currentItem.alt : ''"
            :style="currentItem && currentItem.fp ? 'object-position: ' + currentItem.fp : ''"
            class="max-h-full max-w-full object-contain"
            style="display: none;"
          />
          <video
            x-ref="modalVideo"
            x-show="currentItem && currentItem.type === 'video_file'"
            x-effect="if (currentItem && currentItem.type === 'video_file') { $el.src = currentItem.url; $el.load(); } else { $el.pause(); $el.removeAttribute('src'); }"
            controls
            class="max-h-full max-w-full"
            style="display: none;"
          ></video>
          <div
            x-ref="modalVideoUrl"
            x-show="currentItem && currentItem.type === 'video_url'"
            x-effect="$el.innerHTML = (currentItem && currentItem.type === 'video_url') ? currentItem.html : ''"
            class="aspect-video w-full max-w-4xl [&_iframe]:h-full [&_iframe]:w-full"
            style="display: none;"
          ></div>
        </div>

        {# Bottom bar #}
        <div
          class="flex items-center justify-between px-6 py-4 text-white xl:px-10"
        >
          <span
            class="text-sm font-normal tabular-nums"
            x-text="(current + 1) + ' / ' + total"
          >

          </span>

          <div class="flex items-center gap-6" x-show="total > 1">
            <button
              @click="prev()"
              class="flex h-10 w-10 cursor-pointer items-center justify-center transition-opacity hover:opacity-60"
              aria-label="Precedente"
            >
              {{
                include("icons/generic/chevron-right.svg")|attr({
                  class: "size-4 rotate-180 [&_path]:[stroke-opacity:1]"
                })
              }}
            </button>
            <button
              @click="next()"
              class="flex h-10 w-10 cursor-pointer items-center justify-center transition-opacity hover:opacity-60"
              aria-label="Successivo"
            >
              {{
                include("icons/generic/chevron-right.svg")|attr({
                  class: "size-4 [&_path]:[stroke-opacity:1]"
                })
              }}
            </button>
          </div>

          <button
            @click="close()"
            class="flex h-10 w-10 cursor-pointer items-center justify-center transition-opacity hover:opacity-60"
            aria-label="Chiudi"
          >
            {{ include("icons/generic/close.svg")|attr({ class: "size-6" }) }}
          </button>
        </div>
      </div>
    </template>
  </section>
{% endif %}
