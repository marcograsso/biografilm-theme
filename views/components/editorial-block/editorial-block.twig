{% set heading_class = component.title_size == "big"
  ? "display-h2"
  : "heading-h4 font-semibold"
%}
{% set image_right = component.image_position == "right" %}
{% set grid_cols = component.column_layout == "40_60"
  ? "xl:grid-cols-[2fr_3fr]"
  : component.column_layout == "50_50"
    ? "xl:grid-cols-2"
    : component.column_layout == "1_3"
      ? "xl:grid-cols-[1fr_2fr] 3xl:grid-cols-[1fr_3fr]"
      : component.column_layout == "3_1"
        ? "xl:grid-cols-[2fr_1fr] 3xl:grid-cols-[3fr_1fr]"
        : "xl:grid-cols-[3fr_2fr]"
%}
{% set grid_gap = component.column_layout == "50_50" ? "xl:gap-20" : "" %}
{% set content_self = component.content_align == "center"
  ? "xl:self-center"
  : "xl:self-start"
%}

<section class="w-full">
  <div class="grid grid-cols-1 {{ grid_cols }} {{ grid_gap }}">
    <div
      class="{{ image_right ? "xl:order-last" : "" }} relative overflow-hidden"
    >
      {% if component.image %}
        <div
          class="overlay-blur overlay absolute inset-0 z-10 bg-transparent backdrop-blur-[50px]"
        ></div>
        <img
          src="{{ component.image.url }}"
          alt="{{ component.image.alt }}"
          class="aspect-3/4 h-full w-full object-cover lg:aspect-video 2xl:aspect-2/1"
        />
      {% endif %}
    </div>

    <div
      class="flex flex-col gap-6 self-start px-6 pt-20 pb-10 xl:px-10 xl:py-0 {{
      content_self
      }}"
    >
      {% if component.heading %}
        <h2 class="{{ heading_class }} blur-in">{{ component.heading }}</h2>
      {% endif %}
      {% if component.title %}
        <h6 class="heading-h6 blur-in font-semibold">{{ component.title }}</h6>
      {% endif %}
      {% if component.content %}
        <div
          class="prose text-black0 blur-in max-w-none text-xl leading-[150%]"
        >
          {{ component.content }}
        </div>
      {% endif %}
      {% if component.links %}
        <div class="mt-10 flex flex-col gap-6">
          {% for item in component.links %}
            {% if item.link %}
              {{
                include(
                  "components/button.twig",
                  {
                    as_link: true,
                    size: "lg",
                    variant: item.stile == "secondary"
                      ? "outline"
                      : item.stile == "link" ? "link" : "default",
                    label: item.link.title,
                    attributes: {
                      href: item.link.url,
                      target: item.link.target ? : "_self",
                      class: "w-full"
                    }
                  }
                )
              }}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>
