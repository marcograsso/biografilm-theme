{% set post = component.post %}
{% set post_id = post.ID ?? null %}
{% set post_type = post.post_type ?? null %}

{% if post_type == "proiezione" %}
  {% set film = function("get_field", "film", post_id) %}
  {% set film_id = film.ID ?? null %}
  {% set title = film.post_title ?? post.post_title %}
  {% set image_url = film_id
    ? function("get_the_post_thumbnail_url", film_id, "full")
    : null
  %}
  {% set sezione = film_id
    ? function("wp_get_post_terms", film_id, "sezione")[0]
    : null
  %}
  {% set badges = film_id ? function("wp_get_post_terms", film_id, "badge") : []
  %}
  {% set location = function("wp_get_post_terms", post_id, "location")[0] %}
  {% set data = function("get_field", "data", post_id) %}
  {% set orario = function("get_field", "orario", post_id) %}
  {% set preview_raw = film_id
    ? function("get_field", "preview", film_id)
    : null
  %}
  {% if not preview_raw and film_id %}
    {% set preview_parts = [] %}
    {% set regista = function("get_field", "regista", film_id) %}
    {% set durata = function("get_field", "durata", film_id) %}
    {% set anno = function("get_field", "anno", film_id) %}
    {% set genere = function("wp_get_post_terms", film_id, "genere")[0] %}
    {% if regista %}{% set preview_parts =
      preview_parts|merge([regista])
    %}{% endif %}
    {% if durata %}{% set preview_parts =
      preview_parts|merge([durata])
    %}{% endif %}
    {% if anno %}{% set preview_parts =
      preview_parts|merge([anno])
    %}{% endif %}
    {% if genere %}{% set preview_parts =
      preview_parts|merge([genere.name])
    %}{% endif %}
    {% set preview = preview_parts|join(" / ") %}
  {% else %}
    {% set preview = preview_raw %}
  {% endif %}
{% elseif post_type == "film" %}
  {% set film_id = post_id %}
  {% set title = post.post_title %}
  {% set image_url = function("get_the_post_thumbnail_url", film_id, "full") %}
  {% set sezione = function("wp_get_post_terms", film_id, "sezione")[0] %}
  {% set badges = function("wp_get_post_terms", film_id, "badge") %}
  {% set location = null %}
  {% set data = null %}
  {% set orario = null %}
  {% set preview_raw = function("get_field", "preview", film_id) %}
  {% if not preview_raw %}
    {% set preview_parts = [] %}
    {% set regista = function("get_field", "regista", film_id) %}
    {% set durata = function("get_field", "durata", film_id) %}
    {% set anno = function("get_field", "anno", film_id) %}
    {% set genere = function("wp_get_post_terms", film_id, "genere")[0] %}
    {% if regista %}{% set preview_parts =
      preview_parts|merge([regista])
    %}{% endif %}
    {% if durata %}{% set preview_parts =
      preview_parts|merge([durata])
    %}{% endif %}
    {% if anno %}{% set preview_parts =
      preview_parts|merge([anno])
    %}{% endif %}
    {% if genere %}{% set preview_parts =
      preview_parts|merge([genere.name])
    %}{% endif %}
    {% set preview = preview_parts|join(" / ") %}
  {% else %}
    {% set preview = preview_raw %}
  {% endif %}
{% endif %}

{% if post_id %}
  <section
    class="relative flex h-[547px] w-full items-end justify-end bg-zinc-900 bg-cover bg-center md:items-center"
    style="{{ image_url ? "background-image: url(" ~ image_url ~ ");" : "" }}"
  >
    {% if badges %}
      <div class="absolute top-0 left-0 flex gap-2">
        {% for badge in badges %}
          <span
            class="bg-black/20 px-2 py-1 text-sm font-semibold text-white uppercase backdrop-blur-[50px]"
          >
            {{ badge.name }}
          </span>
        {% endfor %}
      </div>
    {% endif %}

    <div
      class="glass-effect relative flex w-full flex-col justify-between gap-8 bg-black/20 p-10 text-white md:h-full md:w-1/2 xl:w-1/3"
    >
      <div class="flex flex-col gap-3">
        {% if sezione %}
          <p class="text-tight text-sm font-semibold text-white uppercase">
            {{ sezione.name }}
          </p>
        {% endif %}
        {% if title %}
          <h2 class="heading-h6 font-semibold">{{ title }}</h2>
        {% endif %}
        {% if preview %}
          <p class="text-tight text-base">
            {{ preview }}
          </p>
        {% endif %}
      </div>
      {% if data or orario or location %}
        <div class="flex flex-col gap-3">
          {% if data or orario %}
            <p class="text-tight text-base font-semibold">
              {{ data }}{% if orario %}
                · {{ orario }}
              {% endif %}
            </p>
          {% endif %}
          {% if location %}
            <p class="text-tight text-base font-semibold">
              {{ location.name }}
            </p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}
