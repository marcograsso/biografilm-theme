{% set post = component.post %}
{% set post_id = post.ID ?? null %}
{% set post_type = post.post_type ?? null %}

{% if post_type == "proiezione" %}
  {% set film_raw = function("get_field", "film", post_id) %}
  {% set film = film_raw is iterable ? film_raw|first : film_raw %}
  {% set film_id = film.ID ?? null %}

  {# Alternative info from proiezione #}
  {% set alt_title = function("get_field", "titolo_alternativo", post_id) %}
  {% set alt_preview = function("get_field", "preview_alternativa", post_id) %}
  {% set alt_image = function("get_field", "immagine_alternativa", post_id) %}
  {% set alt_badges = function("wp_get_post_terms", post_id, "badge") %}

  {% set title = alt_title ? : film.post_title ?? post.post_title %}
  {% set image_url = alt_image
    ? alt_image.url
    : film_id ? function("get_the_post_thumbnail_url", film_id, "full") : null
  %}
  {% set fp_source_id = alt_image
    ? alt_image.ID
    : film_id ? function("get_post_thumbnail_id", film_id) : null
  %}
  {% set sezione = film_id ? function("get_field", "sezione", film_id)[0] : null
  %}
  {% set badges = alt_badges
    ?
    : film_id ? function("wp_get_post_terms", film_id, "badge") : []
  %}
  {% set location = function("wp_get_post_terms", post_id, "location")[0] %}
  {% set sala_location = function("get_field", "sala_location", post_id) %}
  {% set data = function("get_field", "data", post_id) %}
  {% set orario = function("get_field", "orario", post_id) %}

  {# Preview #}
  {% if alt_preview %}
    {% set preview = alt_preview %}
  {% elseif film_id and function("get_field", "preview", film_id) %}
    {% set preview = function("get_field", "preview", film_id) %}
  {% elseif film_id %}
    {% set preview_parts = [] %}
    {% set regista = function("get_field", "regista", film_id) %}
    {% set durata = function("get_field", "durata", film_id) %}
    {% set anno = function("get_field", "anno", film_id) %}
    {% set genere = function("wp_get_post_terms", film_id, "genere")[0] %}
    {% if regista %}{% set preview_parts =
      preview_parts|merge([regista])
    %}{% endif %}
    {% if durata %}{% set preview_parts =
      preview_parts|merge([durata])
    %}{% endif %}
    {% if anno %}{% set preview_parts =
      preview_parts|merge([anno])
    %}{% endif %}
    {% if genere %}{% set preview_parts =
      preview_parts|merge([genere.name])
    %}{% endif %}
    {% set preview = preview_parts|join(" / ") %}
  {% else %}
    {% set preview = null %}
  {% endif %}
{% elseif post_type == "progetto" %}
  {% set title = post.post_title %}
  {% set fields = function("get_field", "progetto", post_id) %}
  {% set thumb_id = function("get_post_thumbnail_id", post_id) %}
  {% set image_url = thumb_id
    ? function("get_the_post_thumbnail_url", post_id, "full")
    : null
  %}
  {% set fp_source_id = thumb_id %}
  {% set tipologia = function("wp_get_post_terms", post_id, "tipologia-progetto") %}
  {% set progetto_luogo = function("wp_get_post_terms", post_id, "luogo-progetto") %}
  {% set progetto_date_format = {
    anno: "Y",
    anno_mese: "F Y",
    anno_mese_giorno: "d F Y"
  }[fields.precisione_date ?? "anno_mese_giorno"] ?? "d F Y" %}
  {% set preview = fields.descrizione_breve ?? null %}
  {% set badges = [] %}
  {% set sezione = null %}
  {% set location = null %}
  {% set data = null %}
  {% set orario = null %}
{% elseif post_type == "evento" %}
  {% set title = post.post_title %}
  {% set fields = function("get_field", "evento", post_id) %}
  {% set thumb_id = function("get_post_thumbnail_id", post_id) %}
  {% set image_url = thumb_id
    ? function("get_the_post_thumbnail_url", post_id, "full")
    : null
  %}
  {% set fp_source_id = thumb_id %}
  {% set evento_tipologia = function("wp_get_post_terms", post_id, "tipologia-evento") %}
  {% set evento_luogo = function("wp_get_post_terms", post_id, "luogo-evento") %}
  {% set evento_date_format = {
    anno: "Y",
    anno_mese: "F Y",
    anno_mese_giorno: "d F Y"
  }[fields.precisione_date ?? "anno_mese_giorno"] ?? "d F Y" %}
  {% set preview = fields.descrizione_breve ?? null %}
  {% set badges = [] %}
  {% set sezione = null %}
  {% set location = null %}
  {% set data = null %}
  {% set orario = null %}
{% elseif post_type == "film" %}
  {% set film_id = post_id %}
  {% set title = post.post_title %}
  {% set image_url = function("get_the_post_thumbnail_url", film_id, "full") %}
  {% set fp_source_id = function("get_post_thumbnail_id", film_id) %}
  {% set sezione = function("get_field", "sezione", film_id)[0] %}
  {% set badges = function("wp_get_post_terms", film_id, "badge") %}
  {% set location = null %}
  {% set data = null %}
  {% set orario = null %}
  {% set preview_raw = function("get_field", "preview", film_id) %}
  {% if not preview_raw %}
    {% set preview_parts = [] %}
    {% set regista = function("get_field", "regista", film_id) %}
    {% set durata = function("get_field", "durata", film_id) %}
    {% set anno = function("get_field", "anno", film_id) %}
    {% set genere = function("wp_get_post_terms", film_id, "genere")[0] %}
    {% if regista %}{% set preview_parts =
      preview_parts|merge([regista])
    %}{% endif %}
    {% if durata %}{% set preview_parts =
      preview_parts|merge([durata])
    %}{% endif %}
    {% if anno %}{% set preview_parts =
      preview_parts|merge([anno])
    %}{% endif %}
    {% if genere %}{% set preview_parts =
      preview_parts|merge([genere.name])
    %}{% endif %}
    {% set preview = preview_parts|join(" / ") %}
  {% else %}
    {% set preview = preview_raw %}
  {% endif %}
{% endif %}

{% if post_id %}
  {% set permalink = film_id
    ? function("get_permalink", film_id)
    : function("get_permalink", post_id)
  %}
  {% set fp = fp_source_id
    ? function("get_post_meta", fp_source_id, "focalpoint", true)
    : null
  %}
  {% set fp_bg_style = fp
    ? "background-position: " ~ ((fp.left * 100)|round) ~ "% "
      ~ ((fp.top * 100)|round)
      ~ "%;"
    : null
  %}
  <a
    href="{{ permalink }}"
    class="group relative flex h-[547px] w-full items-end justify-end overflow-hidden bg-zinc-900 md:items-center"
  >
    <div
      class="overlay-blur absolute inset-0 z-30 bg-transparent backdrop-blur-[50px]"
    ></div>
    <div
      class="absolute inset-0 bg-cover bg-center transition-transform duration-500 ease-in-out group-hover:scale-[1.1]"
      style="background-image: url({{
      image_url
        ?
        : site.theme.link ~ "/assets/images/fallback-img.jpg"
      }});{{ fp_bg_style }}"
    ></div>
    <div
      class="absolute inset-0 z-20 bg-transparent [mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] backdrop-blur-[0px] transition-[backdrop-filter,_-webkit-backdrop-filter] duration-700 ease-in-out [-webkit-mask-image:radial-gradient(ellipse_at_center,transparent_45%,black_90%)] group-hover:backdrop-blur-[90px]"
    ></div>
    {% if badges %}
      <div class="absolute top-0 left-0 z-40 flex flex-wrap gap-0">
        {% for badge in badges %}
          <span
            class="bg-black/20 px-2 py-1 text-sm font-semibold text-white uppercase backdrop-blur-[50px] {{
            loop.last
              ? ""
              : "border-r border-r-[#575757]"
            }}"
          >
            {{ badge.name }}
          </span>
        {% endfor %}
      </div>
    {% endif %}

    <div
      class="glass-effect 3xl:w-1/4 relative flex w-full flex-col justify-between gap-8 bg-black/20 px-6 py-10 text-white md:h-full md:w-1/2 lg:px-6 xl:w-1/3"
    >
      <div class="flex flex-col gap-3">
        {% if post_type == "progetto" and tipologia %}
          <p
            class="text-tight blur-in text-sm font-semibold text-white uppercase"
          >
            {{ tipologia|map(t => t.name)|join(" · ") }}
          </p>
        {% elseif post_type == "evento" and evento_tipologia %}
          <p
            class="text-tight blur-in text-sm font-semibold text-white uppercase"
          >
            {{ evento_tipologia|map(t => t.name)|join(" · ") }}
          </p>
        {% elseif sezione %}
          <p
            class="text-tight blur-in text-sm font-semibold text-white uppercase"
          >
            {{ sezione.post_title }}
          </p>
        {% endif %}
        {% if title %}
          <h2
            class="blur-in heading-h6 font-semibold transition-opacity duration-300"
          >
            {{ title }}
          </h2>
        {% endif %}
        {% if preview %}
          <p class="text-tight blur-in text-base">
            {{ preview }}
          </p>
        {% endif %}
      </div>
      {% if post_type == "evento" and (fields.data_inizio or fields.data_fine or evento_luogo) %}
        <div class="flex flex-col gap-3">
          {% if fields.data_inizio or fields.data_fine %}
            {% set same_year = fields.data_inizio and fields.data_fine and fields.data_inizio|date("Y") == fields.data_fine|date("Y") %}
            {% set same_month = same_year and fields.data_inizio|date("m") == fields.data_fine|date("m") %}
            <p class="text-tight blur-in text-base font-semibold">
              {% if fields.data_inizio and fields.data_fine %}
                {% if same_month %}
                  {{ fields.data_inizio|date("d") }} — {{ fields.data_fine|date("d F Y") }}
                {% elseif same_year %}
                  {{ fields.data_inizio|date("d F") }} — {{ fields.data_fine|date("d F Y") }}
                {% else %}
                  {{ fields.data_inizio|date(evento_date_format) }} — {{ fields.data_fine|date(evento_date_format) }}
                {% endif %}
              {% elseif fields.data_inizio %}
                {{ fields.data_inizio|date(evento_date_format) }}
              {% else %}
                {{ fields.data_fine|date(evento_date_format) }}
              {% endif %}
            </p>
          {% endif %}
          {% if evento_luogo %}
            <p class="text-tight blur-in text-base font-semibold">
              {{ evento_luogo|map(t => t.name)|join(" / ") }}
            </p>
          {% endif %}
        </div>
      {% elseif post_type == "progetto" and (fields.periodo_inizio or fields.periodo_fine or progetto_luogo) %}
        <div class="flex flex-col gap-3">
          {% if fields.periodo_inizio or fields.periodo_fine %}
            <p class="text-tight blur-in text-base font-semibold">
              {% if fields.periodo_inizio %}{{ fields.periodo_inizio|date(progetto_date_format) }}{% endif %}
              {% if fields.periodo_fine %} — {{ fields.periodo_fine|date(progetto_date_format) }}{% endif %}
            </p>
          {% endif %}
          {% if progetto_luogo %}
            <p class="text-tight blur-in text-base font-semibold">
              {{ progetto_luogo|map(t => t.name)|join(" / ") }}
            </p>
          {% endif %}
        </div>
      {% elseif data or orario or location %}
        <div class="flex flex-col gap-3">
          {% if data or orario %}
            <p class="text-tight blur-in text-base font-semibold">
              {{ data|date("d F Y") }}{% if orario %}
                · {{ orario|date("H:i") }}
              {% endif %}
            </p>
          {% endif %}
          {% if location %}
            <p class="text-tight blur-in text-base font-semibold">
              {{ location.name }}{{ sala_location ? " – " ~ sala_location : "" }}
            </p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </a>
{% endif %}
