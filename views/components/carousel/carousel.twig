<div class="carousel-wrapper w-full">
<div
  class="swiper carousel aspect-3/4 w-full md:aspect-12/10 lg:aspect-12/5"
>
  <div class="swiper-wrapper">
    {% for slide in component.carousel_slides %}
      {% set fp = slide.background_image
        ? function(
          "get_post_meta",
          slide.background_image.ID,
          "focalpoint",
          true
        )
        : null
      %}
      {% set fp_bg_style = fp
        ? "background-position: " ~ ((fp.left * 100)|round) ~ "% "
          ~ ((fp.top * 100)|round)
          ~ "%;"
        : null
      %}
      <div
        class="swiper-slide relative aspect-3/4 w-full overflow-hidden bg-zinc-900 md:aspect-12/10 lg:aspect-12/5"
      >
        {% if slide.background_video %}
          <video
            class="carousel-bg absolute inset-0 w-full object-cover"
            src="{{ slide.background_video.url }}"
            autoplay
            muted
            loop
            playsinline
          ></video>
        {% elseif slide.background_image %}
          <div
            class="carousel-bg absolute inset-0 bg-cover bg-center"
            style="background-image: url({{ slide.background_image.url }});{{
            fp_bg_style
            }}"
          ></div>
        {% endif %}
        <div
          class="overlay-blur absolute inset-0 z-30 bg-transparent backdrop-blur-[50px]"
        ></div>
        {% if
          slide.logo
            or slide.title
            or slide.subtitle
            or slide.link
            or slide.description %}
          <div
            class="glass-effect absolute bottom-0 left-0 flex flex-col gap-6 bg-white/20 p-6 pb-20 md:pb-6 lg:pl-10 {{
            slide.text_width == "w-1/3"
              ? "w-full 3xl:w-1/4 md:w-1/2 xl:w-1/3"
              : "w-full md:w-1/2"
            }}"
            style="{{
            slide.text_color
              ? " color: " ~ slide.text_color ~ ";"
              : ""
            }}"
          >
            {% if slide.logo %}
              <img
                src="{{ slide.logo.url }}"
                alt="{{ slide.logo.alt }}"
                class="self-start object-contain"
              />
            {% endif %}
            {% if slide.title or slide.subtitle %}
              <div>
                {% if slide.title %}
                  <h2
                    class="heading-h6 font-sans leading-[125%] font-semibold tracking-normal"
                  >
                    {{ slide.title }}
                  </h2>
                {% endif %}
                {% if slide.subtitle %}
                  <p
                    class="heading-h6 font-sans leading-[125%] font-normal tracking-normal"
                  >
                    {{ slide.subtitle }}
                  </p>
                {% endif %}
              </div>
            {% endif %}
            {% if slide.link %}
              {{
                include(
                  "components/button.twig",
                  {
                    label: slide.link.title,
                    as_link: true,
                    variant: "default",
                    size: "lg",
                    attributes: {
                      href: slide.link.url,
                      target: slide.link.target ? : "_self"
                    }
                  }
                )
              }}
            {% endif %}
            {% if slide.description %}
              <span class="text-tight block text-2xl opacity-90">
                {{ slide.description }}
              </span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>
{% if component.carousel_slides|length > 1 %}
  <div class="hero-carousel-nav giurie-nav carousel-nav-below">
    <button class="swiper-button-prev" aria-label="Precedente"></button>
    <div class="swiper-pagination" role="tablist"></div>
    <button class="swiper-button-next" aria-label="Successivo"></button>
  </div>
{% endif %}
</div>
