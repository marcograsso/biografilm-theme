{% set film_raw = function("get_field", "film", proiezione.ID) %}
{% set film = film_raw is iterable ? film_raw|first : film_raw %}
{% set film_id = film.ID ?? null %}

{# Alternative info from proiezione #}
{% set alt_title = function("get_field", "titolo_alternativo", proiezione.ID) %}
{% set alt_preview =
  function("get_field", "preview_alternativa", proiezione.ID)
%}
{% set alt_image =
  function("get_field", "immagine_alternativa", proiezione.ID)
%}
{% set alt_badges = function("wp_get_post_terms", proiezione.ID, "badge") %}

{# Image & focal point #}
{% if alt_image %}
  {% set image_url = alt_image.url %}
  {% set fp = function("get_post_meta", alt_image.ID, "focalpoint", true) %}
{% else %}
  {% set image_url = film_id
    ? function("get_the_post_thumbnail_url", film_id, "large")
    : null
  %}
  {% set thumb_id = film_id ? function("get_post_thumbnail_id", film_id) : null
  %}
  {% set fp = thumb_id
    ? function("get_post_meta", thumb_id, "focalpoint", true)
    : null
  %}
{% endif %}
{% set fp_style = fp
  ? "object-position: " ~ ((fp.left * 100)|round) ~ "% "
    ~ ((fp.top * 100)|round)
    ~ "%;"
  : null
%}

{# Title #}
{% set title = alt_title ? : film.post_title ?? null %}

{# Badges #}
{% set badges = alt_badges
  ?
  : film_id ? function("wp_get_post_terms", film_id, "badge") : []
%}

{# Sezione (always from film) #}
{% set sezione = film_id
  ? function("wp_get_post_terms", film_id, "sezione")[0]
  : null
%}

{# Preview #}
{% if alt_preview %}
  {% set preview = alt_preview %}
{% elseif film_id and function("get_field", "preview", film_id) %}
  {% set preview = function("get_field", "preview", film_id) %}
{% elseif film_id %}
  {% set preview_parts = [] %}
  {% set regista = function("get_field", "regista", film_id) %}
  {% set durata = function("get_field", "durata", film_id) %}
  {% set anno = function("get_field", "anno", film_id) %}
  {% set genere = function("wp_get_post_terms", film_id, "genere")[0] %}
  {% if regista %}{% set preview_parts =
    preview_parts|merge([regista])
  %}{% endif %}
  {% if durata %}{% set preview_parts =
    preview_parts|merge([durata])
  %}{% endif %}
  {% if anno %}{% set preview_parts = preview_parts|merge([anno]) %}{% endif %}
  {% if genere %}{% set preview_parts =
    preview_parts|merge([genere.name])
  %}{% endif %}
  {% set preview = preview_parts|join(" / ") %}
{% else %}
  {% set preview = null %}
{% endif %}

{% set location = function("wp_get_post_terms", proiezione.ID, "location")[0] %}
{% set film_url = film_id ? function("get_permalink", film_id) : null %}

<a
  href="{{ film_url }}"
  class="group border-b-stroke relative col-span-1 block border-b transition-colors duration-300"
>
  {% if badges %}
    <div class="absolute top-0 flex flex-wrap gap-0">
      {% for badge in badges %}
        <span
          class="bg-black/20 px-2 py-1 text-sm font-semibold text-white uppercase backdrop-blur-[50px]{% if not loop.last %} border-r border-r-[#575757]{% endif %}"
        >
          {{ badge.name }}
        </span>
      {% endfor %}
    </div>
  {% endif %}
  <div class="aspect-video w-full overflow-hidden bg-gray-200">
    <img
      src="{{
      image_url
        ?
        : site.theme.link ~ "/assets/images/fallback-img.jpg"
      }}"
      alt="{{ title }}"
      class="h-full w-full object-cover"
      style="{{ fp_style }}"
    />
  </div>

  <div class="border-l-stroke flex flex-col gap-10 px-6 py-10 lg:border-l">
    <!-- Up -->
    <div class="flex flex-col gap-3">
      {% if sezione %}
        <p class="text-tight text-red text-sm font-semibold uppercase">
          {{ sezione.name }}
        </p>
      {% endif %}
      {% if title %}
        <h5 class="text-tight text-2xl font-semibold">{{ title }}</h5>
      {% endif %}
      {% if preview %}
        <p class="text-tight text-base text-black">
          {{ preview }}
        </p>
      {% endif %}
    </div>
    <!-- Down -->
    <div class="flex flex-col gap-3">
      {% if proiezione.data or proiezione.orario %}
        <p class="text-tight text-base font-semibold text-black">
          {{ proiezione.data|date("d F Y") }}{% if proiezione.orario %}
            · {{ proiezione.orario|date("H:i") }}
          {% endif %}
        </p>
      {% endif %}
      {% if location %}
        <p class="text-tight text-base font-semibold text-black">
          {{ location.name }}
        </p>
      {% endif %}
    </div>
  </div>
</a>
